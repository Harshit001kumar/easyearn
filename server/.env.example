# Server
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-frontend.onrender.com

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/freecash?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-backend.onrender.com/api/auth/discord/callback

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_ADMIN_CHANNEL_ID=your_admin_channel_id
DISCORD_LIVE_EARNINGS_CHANNEL_ID=your_live_earnings_channel_id
DISCORD_PAYMENT_PROOFS_CHANNEL_ID=your_payment_proofs_channel_id
DISCORD_GUILD_ID=your_guild_id

# ShrinkMe
SHRINKME_API_KEY=your_shrinkme_api_key

# Offerwalls (RevToo)
REVTOO_API_KEY=your_revtoo_api_key
REVTOO_SECRET_KEY=your_revtoo_secret_key

# hCaptcha
HCAPTCHA_SECRET=your_hcaptcha_secret_key

# Faucet Config
FAUCET_COOLDOWN_MINUTES=5
FAUCET_MIN_REWARD=1
FAUCET_MAX_REWARD=5

# Admin
ADMIN_EMAILS=admin@freecash.com
